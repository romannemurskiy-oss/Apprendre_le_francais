# ==========================
# ANAGRAM GAME
# ==========================
@bot.callback_query_handler(func=lambda call: call.data == "game_unscramble")
def start_unscramble(call):
    chat_id = str(call.message.chat.id)
    diff = users[chat_id]["difficulty"]

    word = random.choice(quiz_levels[diff])[0].upper()
    scrambled = list(word)
    random.shuffle(scrambled)

    while "".join(scrambled) == word:
        random.shuffle(scrambled)

    users[chat_id]["game_answer"] = word
    users[chat_id]["game_state"] = "unscramble"
    save_data()

    bot.send_message(chat_id,
                     f"🧩 **Anagramme**\n\nRemettez les lettres dans l'ordre :\n\n🔥 ` {' '.join(scrambled)} ` 🔥",
                     parse_mode="Markdown")
