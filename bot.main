# ==========================
# CHECK GAME TEXT ANSWERS
# ==========================
@bot.message_handler(func=lambda msg: users.get(str(msg.chat.id), {}).get("game_answer", "") != "")
def check_game(message):
    chat_id = str(message.chat.id)
    correct = users[chat_id]["game_answer"]
    state = users[chat_id]["game_state"]

    if state in ["unscramble", "math", "spy"]:
        if message.text.strip().lower() == correct.lower():
            users[chat_id]["score"] += 2
            users[chat_id]["game_answer"] = ""
            users[chat_id]["game_state"] = ""
            save_data()

            check_achievements(chat_id)

            bot.send_message(chat_id,
                             f"🎉 **Bravo !**\n\nLa réponse était : *{correct}* (+2 points)",
                             parse_mode="Markdown")
        else:
            bot.send_message(chat_id, "❌ Ce n'est pas ça... Réessaie !")


