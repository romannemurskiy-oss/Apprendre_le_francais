# ==========================
# VOCAB QUIZ GENERATOR
# ==========================
def generate_quiz(chat_id, mode, message_id=None):
    diff = users[chat_id]["difficulty"]
    pair = random.choice(quiz_levels[diff])

    if mode == "fr_en":
        q_word, correct = pair[0], pair[1]
        all_opts = [p[1] for lvl in quiz_levels.values() for p in lvl]
    else:
        q_word, correct = pair[1], pair[0]
        all_opts = [p[0] for lvl in quiz_levels.values() for p in lvl]

    wrong = random.sample(list(set([w for w in all_opts if w != correct])), 3)
    options = wrong + [correct]
    random.shuffle(options)

    markup = types.InlineKeyboardMarkup()
    for o in options:
        markup.add(types.InlineKeyboardButton(o, callback_data=f"q|{correct}|{o}|{mode}"))

    text = f"Traduisez : *{q_word}*"

    if message_id:
        bot.edit_message_text(text, chat_id, message_id, reply_markup=markup, parse_mode="Markdown")
    else:
        bot.send_message(chat_id, text, reply_markup=markup, parse_mode="Markdown")


@bot.callback_query_handler(func=lambda call: call.data in ["quiz_fr_en", "quiz_en_fr"])
def start_quiz(call):
    chat_id = str(call.message.chat.id)
    mode = call.data.split("_", 1)[1]

    update_streak(chat_id)

    generate_quiz(chat_id, mode, call.message.message_id)


@bot.callback_query_handler(func=lambda call: call.data.startswith("q|"))
def handle_quiz_answer(call):
    parts = call.data.split("|")
    correct = parts[1]
    chosen = parts[2]
    mode = parts[3]
    chat_id = str(call.message.chat.id)

    users[chat_id]["quizzes_done"] += 1
    update_streak(chat_id)

    if correct == chosen:
        users[chat_id]["score"] += 1
        res = "✅ C'est correct ! (+1 point)"
    else:
        res = f"❌ Faux. C'était : *{correct}*"

    save_data()
    check_achievements(chat_id)

    next_kb = types.InlineKeyboardMarkup()
    next_kb.add(types.InlineKeyboardButton("Suivant ➡️", callback_data=f"next_quiz|{mode}"))

    bot.edit_message_text(res, chat_id, call.message.message_id,
                          reply_markup=next_kb, parse_mode="Markdown")


@bot.callback_query_handler(func=lambda call: call.data.startswith("next_quiz|"))
def next_q(call):
    chat_id = str(call.message.chat.id)
    mode = call.data.split("|")[1]
    generate_quiz(chat_id, mode, call.message.message_id)


# ==========================
# CONJUGATION QUIZ
# ==========================
def generate_conjugation_quiz(chat_id, message_id=None):
    diff = users[chat_id]["difficulty"]
    verb, group = random.choice(verb_quiz[diff])

    if group not in conjugation_endings:
        group = "er"

    pronoun = random.choice(list(conjugation_endings[group].keys()))
    ending = conjugation_endings[group][pronoun]

    stem = verb[:-2]
    question = f"{pronoun} {stem}___"

    all_endings = list(set(conjugation_endings[group].values()))
    wrong = random.sample([x for x in all_endings if x != ending], min(3, len(all_endings) - 1))
    choices = wrong + [ending]
    random.shuffle(choices)

    markup = types.InlineKeyboardMarkup()
    for c in choices:
        text_opt = c if c != "" else "(rien)"
        markup.add(types.InlineKeyboardButton(text_opt, callback_data=f"conj|{ending}|{c}"))

    text = f"✍️ *Complète la conjugaison :*\n\n`{question}`"

    if message_id:
        bot.edit_message_text(text, chat_id, message_id, reply_markup=markup, parse_mode="Markdown")
    else:
        bot.send_message(chat_id, text, reply_markup=markup, parse_mode="Markdown")


@bot.callback_query_handler(func=lambda call: call.data == "quiz_conj")
def start_conj_quiz(call):
    chat_id = str(call.message.chat.id)
    update_streak(chat_id)
    generate_conjugation_quiz(chat_id, call.message.message_id)


@bot.callback_query_handler(func=lambda call: call.data.startswith("conj|"))
def handle_conj_answer(call):
    parts = call.data.split("|")
    correct = parts[1]
    chosen = parts[2]
    chat_id = str(call.message.chat.id)

    users[chat_id]["quizzes_done"] += 1
    update_streak(chat_id)

    if chosen == correct:
        users[chat_id]["score"] += 1
        res = "✅ Correct ! +1 point"
    else:
        show_correct = correct if correct != "" else "(rien)"
        res = f"❌ Faux. Bonne réponse : *{show_correct}*"

    save_data()
    check_achievements(chat_id)

    next_kb = types.InlineKeyboardMarkup()
    next_kb.add(types.InlineKeyboardButton("Suivant ➡️", callback_data="next_conj"))

    bot.edit_message_text(res, chat_id, call.message.message_id,
                          reply_markup=next_kb, parse_mode="Markdown")


@bot.callback_query_handler(func=lambda call: call.data == "next_conj")
def next_conj(call):
    chat_id = str(call.message.chat.id)
    generate_conjugation_quiz(chat_id, call.message.message_id)


# ==========================
# GRAMMAR QUIZ
# ==========================
def generate_grammar_quiz(chat_id, message_id=None):
    diff = users[chat_id]["difficulty"]
    phrase, correct, options = random.choice(grammar_quiz[diff])

    random.shuffle(options)

    markup = types.InlineKeyboardMarkup()
    for opt in options:
        markup.add(types.InlineKeyboardButton(opt, callback_data=f"g|{correct}|{opt}"))

    text = f"📘 Complète la phrase :\n\n{phrase}"

    if message_id:
        bot.edit_message_text(text, chat_id, message_id, reply_markup=markup)
    else:
        bot.send_message(chat_id, text, reply_markup=markup)

@bot.callback_query_handler(func=lambda call: call.data == "quiz_grammar")
def start_grammar(call):
    chat_id = str(call.message.chat.id)
    update_streak(chat_id)
    generate_grammar_quiz(chat_id, call.message.message_id)


@bot.callback_query_handler(func=lambda call: call.data.startswith("g|"))
def handle_grammar_answer(call):
    parts = call.data.split("|")
    correct = parts[1]
    chosen = parts[2]
    chat_id = str(call.message.chat.id)

    users[chat_id]["quizzes_done"] += 1
    update_streak(chat_id)

    if chosen == correct:
        users[chat_id]["score"] += 1
        res = "✅ Correct ! +1 point"
    else:
        res = f"❌ Faux. La bonne réponse était : *{correct}*"

    save_data()
    check_achievements(chat_id)

    next_kb = types.InlineKeyboardMarkup()
    next_kb.add(types.InlineKeyboardButton("Suivant ➡️", callback_data="next_grammar"))

    bot.edit_message_text(res, chat_id, call.message.message_id,
                          reply_markup=next_kb)


@bot.callback_query_handler(func=lambda call: call.data == "next_grammar")
def next_grammar(call):
    chat_id = str(call.message.chat.id)
    generate_grammar_quiz(chat_id, call.message.message_id)


# ==========================
# RUN BOT
# ==========================
if __name__ == "__main__":
    print("Бот запускається...")

    # Видаляємо вебхук, щоб він не конфліктував
    try:
        bot.remove_webhook()
    except:
        pass

    while True:
        try:
            print("Спроба підключення до Telegram...")
            bot.polling(none_stop=True, interval=2, timeout=20)
        except Exception as e:
            print(f"Помилка мережі: {e}")
            print("Ймовірно, хостинг блокує Telegram. Чекаю 15 секунд...")
            time.sleep(15)
