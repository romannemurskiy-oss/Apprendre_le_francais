# ==========================
# DATA SYSTEM
# ==========================
def load_data():
    if not os.path.exists(DATA_FILE):
        return {}
    try:
        with open(DATA_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    except:
        return {}

def save_data():
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(users, f, indent=4, ensure_ascii=False)

users = load_data()


# ==========================
# USER INIT + STREAK SYSTEM
# ==========================
def init_user(chat_id):
    chat_id = str(chat_id)

    if chat_id not in users:
        users[chat_id] = {}

    defaults = {
        "score": 0,
        "difficulty": "facile",
        "game_answer": "",
        "game_state": "",
        "quizzes_done": 0,
        "streak": 0,
        "last_day": "",
        "achievements": []
    }

    for key, val in defaults.items():
        if key not in users[chat_id]:
            users[chat_id][key] = val

    if users[chat_id]["difficulty"] not in quiz_levels:
        users[chat_id]["difficulty"] = "facile"

    save_data()


def update_streak(chat_id):
    today = str(date.today())
    last_day = users[chat_id].get("last_day", "")

    if last_day == "":
        users[chat_id]["streak"] = 1
    else:
        last = datetime.strptime(last_day, "%Y-%m-%d").date()
        now = date.today()

        diff = (now - last).days
        if diff == 1:
            users[chat_id]["streak"] += 1
        elif diff > 1:
            users[chat_id]["streak"] = 1

    users[chat_id]["last_day"] = today
    save_data()


# ==========================
# ACHIEVEMENTS SYSTEM
# ==========================
def check_achievements(chat_id):
    u = users[chat_id]
    ach = set(u.get("achievements", []))

    # Achievements list
    if u["quizzes_done"] >= 10:
        ach.add("🥉 Novice: 10 quiz terminés")
    if u["quizzes_done"] >= 50:
        ach.add("🥈 Étudiant sérieux: 50 quiz terminés")
    if u["quizzes_done"] >= 100:
        ach.add("🥇 Machine: 100 quiz terminés")

    if u["score"] >= 50:
        ach.add("🎖 Apprenti: 50 points")
    if u["score"] >= 100:
        ach.add("🥈 Polyglotte: 100 points")
    if u["score"] >= 200:
        ach.add("🏆 Expert: 200 points")

    if u["streak"] >= 3:
        ach.add("🔥 Régulier: 3 jours d'affilée")
    if u["streak"] >= 7:
        ach.add("🔥 Série forte: 7 jours d'affilée")
    if u["streak"] >= 30:
        ach.add("👑 Légende: 30 jours d'affilée")

    # Hard words achievement
    if u["difficulty"] == "difficile" and u["score"] >= 150:
        ach.add("🥇 Roi Français: Niveau difficile + 150 points")

    u["achievements"] = list(ach)
    save_data()


def get_rank(chat_id):
    scores = []
    for uid in users:
        scores.append((uid, users[uid].get("score", 0)))

    scores.sort(key=lambda x: x[1], reverse=True)

    for i, (uid, sc) in enumerate(scores, start=1):
        if uid == chat_id:
            return i
    return "?"


def get_title(score):
    if score < 30:
        return "Débutant"
    elif score < 80:
        return "Apprenti"
    elif score < 150:
        return "Étudiant"
    elif score < 250:
        return "Avancé"
    else:
        return "Maître"


