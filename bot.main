# ==========================
# TRUE / FALSE GAME
# ==========================
@bot.callback_query_handler(func=lambda call: call.data == "game_truefalse")
def start_truefalse(call):
    chat_id = str(call.message.chat.id)

    statement, is_true = random.choice(true_false_facts)

    users[chat_id]["game_answer"] = "true" if is_true else "false"
    users[chat_id]["game_state"] = "truefalse"
    save_data()

    kb = types.InlineKeyboardMarkup()
    kb.add(types.InlineKeyboardButton("✅ Vrai", callback_data="tf|true"),
           types.InlineKeyboardButton("❌ Faux", callback_data="tf|false"))

    bot.send_message(chat_id,
                     f"✅❌ *Vrai ou Faux ?*\n\n{statement}",
                     reply_markup=kb,
                     parse_mode="Markdown")


@bot.callback_query_handler(func=lambda call: call.data.startswith("tf|"))
def answer_truefalse(call):
    chat_id = str(call.message.chat.id)
    chosen = call.data.split("|")[1]
    correct = users[chat_id]["game_answer"]

    if chosen == correct:
        users[chat_id]["score"] += 2
        res = "✅ Correct ! +2 points"
    else:
        res = "❌ Faux !"

    users[chat_id]["game_answer"] = ""
    users[chat_id]["game_state"] = ""
    save_data()

    check_achievements(chat_id)

    next_kb = types.InlineKeyboardMarkup()
    next_kb.add(types.InlineKeyboardButton("Suivant ➡️", callback_data="game_truefalse"))

    bot.edit_message_text(res, chat_id, call.message.message_id, reply_markup=next_kb)


